# Application Configuration
APP_ENV=development
APP_NAME=NIDS
APP_VERSION=1.0.0
DEBUG=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# Security
SECRET_KEY=change-this-to-a-secure-random-string-in-production
API_KEY_HEADER=X-API-Key
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

# Model Configuration
MODEL_PATH=models/nids_model.pkl
MODEL_VERSION=1.0.0
INFERENCE_TIMEOUT_MS=100
MAX_BATCH_SIZE=1000

# Alert Configuration
ALERT_QUEUE_SIZE=10000
ALERT_RETENTION_HOURS=24
HIGH_SEVERITY_THRESHOLD=0.8
MEDIUM_SEVERITY_THRESHOLD=0.5

# Rate Limiting
RATE_LIMIT_PER_MINUTE=1000
RATE_LIMIT_BURST=100

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/nids.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Database (for alert persistence)
DB_TYPE=sqlite
DB_PATH=data/nids.db
# For production PostgreSQL:
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=nids
# DB_USER=nids_user
# DB_PASSWORD=secure_password

# Redis (for distributed caching)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Data Paths
DATA_DIR=data
CICIDS2017_PATH=data/CICIDS2017.csv
MODEL_DIR=models

# Training Configuration
TRAIN_TEST_SPLIT=0.2
USE_SMOTE=true
SMOTE_K_NEIGHBORS=5
XGBOOST_N_ESTIMATORS=200
XGBOOST_MAX_DEPTH=8
XGBOOST_LEARNING_RATE=0.1

# Performance Targets
TARGET_F1_SCORE=0.97
TARGET_FPR=0.02
TARGET_LATENCY_MS=50
